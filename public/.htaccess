<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Let real files and directories load normally.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Send all other requests to the React app entry.
  RewriteRule ^ index.html [L]
</IfModule>
